type Props = {
  slug: string
}

export default function WorksheetCard({ slug }: Props) {

  const title = slug.replace(/-/g, " ")

  return (
    <div className="bg-white shadow-md rounded-xl p-4 text-center">

      <img
        src={`/worksheets/${slug}.png`}
        alt={title}
        style={{ borderRadius: "10px", marginBottom: "10px" }}
      />

      <h3 style={{ fontWeight: "bold" }}>
        {title}
      </h3>

      <a
        href={`/worksheet/${slug}`}
        style={{
          display: "inline-block",
          marginTop: "10px",
          background: "#22c55e",
          color: "white",
          padding: "8px 16px",
          borderRadius: "8px",
          textDecoration: "none"
        }}
      >
        View Worksheet
      </a>

    </div>
  )
}
